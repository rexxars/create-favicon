{
  "name": "create-favicon",
  "version": "2.1.0",
  "description": "Create modern favicon variations from source image",
  "keywords": [
    "favicon",
    "generate"
  ],
  "homepage": "https://github.com/rexxars/create-favicon#readme",
  "bugs": {
    "url": "https://github.com/rexxars/create-favicon/issues"
  },
  "license": "MIT",
  "author": "Espen Hovlandsdal <espen@hovlandsdal.com>",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/rexxars/create-favicon.git"
  },
  "bin": {
    "create-favicon": "./bin/create-favicon.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc --project tsconfig.dist.json",
    "prebuild": "npm run clean",
    "format": "oxfmt --write .",
    "lint": "oxfmt --check . && oxlint && tsc --noEmit",
    "test": "npm run test:api && npm run test:cli",
    "test:api": "vitest --reporter=verbose test/api.test.ts",
    "test:cli": "npm run build && vitest --reporter=verbose test/cli.test.ts",
    "posttest": "npm run lint",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "sharp": "^0.34.0"
  },
  "devDependencies": {
    "@sanity/semantic-release-preset": "^6.0.0",
    "@types/node": "^22.0.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "typescript": "^5.8.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=22"
  }
}
